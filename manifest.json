{
  "manifest_version": 3,
  "name": "SecureView",
  "version": "1.0.2",
  "description": "Track active browsing time, get AI-powered site categorization, and visualize your daily web activities - all in one dashboard.",
  "permissions": [
    "tabs",
    "storage",
    "alarms",
    "idle"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background/background.js"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": "icons/icon.png"
  },
  "icons": {
    "16": "icons/icon.png",
    "32": "icons/icon.png",
    "48": "icons/icon.png",
    "128": "icons/icon.png"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["shared/logger.js", "content/content_script.js"]
    }
  ]
}
